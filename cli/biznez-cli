# ===== uninstall ============================================================
_usage_uninstall() {
    cat <<'USAGE'
Usage: biznez-cli uninstall [flags]

Uninstall the Biznez Runtime release.

Flags:
  -r, --release <name>     Release name (default: biznez)
  -n, --namespace <ns>     Target namespace
  --yes                    Skip confirmation prompt
  --delete-namespace       Delete the namespace after uninstall
  --delete-pvcs            Delete PVCs matching the release
  -h, --help               Show this help
USAGE
}

cmd_uninstall() {
    local yes=false delete_ns=false delete_pvcs=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --yes)              yes=true; shift ;;
            --delete-namespace) delete_ns=true; shift ;;
            --delete-pvcs)      delete_pvcs=true; shift ;;
            -h|--help)          _usage_uninstall; return 0 ;;
            *)                  die "Unknown flag for uninstall: $1" ;;
        esac
    done

    _resolve_namespace
    _require_cmd helm
    _require_cmd kubectl

    # Confirmation
    if [ "$yes" = "false" ]; then
        printf "Uninstall release '%s' from namespace '%s'? [y/N] " "$RELEASE" "$NAMESPACE"
        local _answer
        read -r _answer
        case "$_answer" in
            y|Y|yes|Yes) ;;
            *) die "Aborted." "$EXIT_ABORT" ;;
        esac
    fi

    info "Uninstalling release '$RELEASE'..."
    local _rc=0
    helm uninstall "$RELEASE" -n "$NAMESPACE" || _rc=$?
    if [ "$_rc" -ne 0 ]; then
        die "Helm uninstall failed." "$EXIT_KUBE"
    fi
    ok "Release '$RELEASE' uninstalled"

    # Delete PVCs
    if [ "$delete_pvcs" = "true" ]; then
        info "Deleting PVCs for release '$RELEASE'..."
        kubectl delete pvc -l "app.kubernetes.io/instance=$RELEASE" -n "$NAMESPACE" --ignore-not-found || true
        ok "PVCs deleted"
    fi

    # Delete namespace
    if [ "$delete_ns" = "true" ]; then
        if [ "$yes" = "false" ]; then
            printf "Delete namespace '%s'? This is irreversible. [y/N] " "$NAMESPACE"
            local _ns_answer
            read -r _ns_answer
            case "$_ns_answer" in
                y|Y|yes|Yes) ;;
                *) info "Skipping namespace deletion."; return 0 ;;
            esac
        fi
        info "Deleting namespace '$NAMESPACE'..."
        kubectl delete namespace "$NAMESPACE" || true
        ok "Namespace '$NAMESPACE' deleted"
    fi
}

# ===== oidc-discover ========================================================
_usage_oidc_discover() {
    cat <<'USAGE'
Usage: biznez-cli oidc-discover --issuer <url>

Fetch OIDC provider metadata and show suggested configuration.

Flags:
  --issuer <url>    OIDC issuer URL (required)
  -h, --help        Show this help
USAGE
}

cmd_oidc_discover() {
    local issuer=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --issuer) issuer="$2"; shift 2 ;;
            -h|--help) _usage_oidc_discover; return 0 ;;
            *)         die "Unknown flag for oidc-discover: $1" ;;
        esac
    done

    if [ -z "$issuer" ]; then
        die "Missing required flag: --issuer <url>" "$EXIT_ERROR"
    fi

    _require_cmd curl

    local _well_known="${issuer%/}/.well-known/openid-configuration"
    info "Fetching OIDC metadata from: $_well_known"

    local _response _rc=0
    _response=$(curl -sf --max-time 10 "$_well_known" 2>/dev/null) || _rc=$?

    if [ "$_rc" -ne 0 ] || [ -z "$_response" ]; then
        die "Could not fetch OIDC metadata from $_well_known" "$EXIT_NETWORK"
    fi

    echo ""
    echo "=== OIDC Provider Metadata ==="
    if command -v jq >/dev/null 2>&1; then
        echo "$_response" | jq '{issuer, authorization_endpoint, token_endpoint, jwks_uri, scopes_supported, grant_types_supported}' 2>/dev/null || echo "$_response"
    else
        echo "$_response"
    fi

    # Extract jwks_uri for suggestion
    local _jwks_uri
    if command -v jq >/dev/null 2>&1; then
        _jwks_uri=$(echo "$_response" | jq -r '.jwks_uri' 2>/dev/null) || true
    else
        _jwks_uri=$(echo "$_response" | grep -o '"jwks_uri"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"\(http[^"]*\)".*/\1/') || true
    fi

    echo ""
    echo "=== Suggested values.yaml ==="
    cat <<EOF
auth:
  mode: oidc
  oidc:
    issuer: "${issuer}"
    jwksUrl: "${_jwks_uri:-<discovered-jwks-uri>}"
    audience: "<your-oauth2-client-id>"
EOF
}

# ===== support-bundle =======================================================
_usage_support_bundle() {
    cat <<'USAGE'
Usage: biznez-cli support-bundle [flags]

Collect diagnostic data for troubleshooting.

Flags:
  -r, --release <name>    Release name (default: biznez)
  -n, --namespace <ns>    Target namespace
  -f, --values <file>     Include redacted values file(s) in bundle
  --output <file>         Output archive path (default: biznez-support-YYYYMMDD-HHMMSS.tar.gz)
  -h, --help              Show this help
USAGE
}

_redact_values() {
    # Multi-format redaction: YAML, ENV, URL-embedded credentials
    sed -E \
        -e 's/(encryptionKey|jwtSecret|password|apiKey|secretKey|publicKey|databaseUrl):[[:space:]]*"?[^"]*"?/\1: "***REDACTED***"/g' \
        -e 's/(ENCRYPTION_KEY|JWT_SECRET_KEY|DATABASE_URL|POSTGRES_PASSWORD|LLM_API_KEY|LANGFUSE_SECRET_KEY|LANGFUSE_PUBLIC_KEY)=.*/\1=***REDACTED***/g' \
        -e 's|(postgresql://[^:]+:)[^@]+(@)|\1***REDACTED***\2|g'
}

cmd_support_bundle() {
    local _output_file=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--values) VALUES_FILES+=("$2"); shift 2 ;;
            --output)    _output_file="$2"; shift 2 ;;
            -h|--help)   _usage_support_bundle; return 0 ;;
            *)           die "Unknown flag for support-bundle: $1" ;;
        esac
    done

    _resolve_namespace
    _require_cmd kubectl
    _require_cmd helm
    _require_cmd tar

    local _bundle_dir
    _bundle_dir=$(mktemp -d)

    info "Collecting support bundle for release '$RELEASE' in '$NAMESPACE'..."

    # Release info
    _collect_optional "helm list" "$_bundle_dir/helm-list.txt" \
        helm list -n "$NAMESPACE"

    # Helm values (redacted)
    local _raw_values
    _raw_values=$(helm get values "$RELEASE" -n "$NAMESPACE" 2>/dev/null) || true
    if [ -n "$_raw_values" ]; then
        echo "$_raw_values" | _redact_values > "$_bundle_dir/helm-values.yaml"
        ok "Collected helm-values (redacted)"
    fi

    # Rendered manifests (no secrets in manifests)
    _collect_optional "helm manifest" "$_bundle_dir/helm-manifest.yaml" \
        helm get manifest "$RELEASE" -n "$NAMESPACE"

    # Namespaced resources
    _collect_optional "pods/svc/events" "$_bundle_dir/resources.yaml" \
        kubectl get pods,svc,ep,events -n "$NAMESPACE" -o yaml

    # Pod describe (detailed pod status, events, conditions)
    _collect_optional "pod-describe" "$_bundle_dir/pod-describe.txt" \
        kubectl describe pods -l "app.kubernetes.io/instance=$RELEASE" -n "$NAMESPACE"

    _collect_optional "ingress" "$_bundle_dir/ingress.yaml" \
        kubectl get ingress -n "$NAMESPACE" -o yaml

    _collect_optional "pvc" "$_bundle_dir/pvc.yaml" \
        kubectl get pvc -n "$NAMESPACE" -o yaml

    _collect_optional "networkpolicy" "$_bundle_dir/networkpolicy.yaml" \
        kubectl get networkpolicy -n "$NAMESPACE" -o yaml

    # Pod logs
    local _backend_deploy _frontend_deploy _gateway_deploy
    _backend_deploy=$(_find_resource deployment backend) || true
    _frontend_deploy=$(_find_resource deployment frontend) || true
    _gateway_deploy=$(_find_resource deployment gateway) || true

    if [ -n "$_backend_deploy" ]; then
        _collect_optional "backend logs" "$_bundle_dir/logs-backend.txt" \
            kubectl logs "$_backend_deploy" -n "$NAMESPACE" --tail=500
    fi
    if [ -n "$_frontend_deploy" ]; then
        _collect_optional "frontend logs" "$_bundle_dir/logs-frontend.txt" \
            kubectl logs "$_frontend_deploy" -n "$NAMESPACE" --tail=500
    fi
    if [ -n "$_gateway_deploy" ]; then
        _collect_optional "gateway logs" "$_bundle_dir/logs-gateway.txt" \
            kubectl logs "$_gateway_deploy" -n "$NAMESPACE" --tail=500
    fi

    # Versions
    kubectl version --client > "$_bundle_dir/kubectl-version.txt" 2>&1 || true
    helm version > "$_bundle_dir/helm-version.txt" 2>&1 || true

    # Cluster-wide (optional — may fail due to RBAC)
    _collect_optional "nodes" "$_bundle_dir/nodes.txt" \
        kubectl get nodes -o wide
    # Redact IPs from nodes output
    if [ -f "$_bundle_dir/nodes.txt" ]; then
        sed -E 's/[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/x.x.x.x/g' "$_bundle_dir/nodes.txt" > "$_bundle_dir/nodes-redacted.txt"
        mv "$_bundle_dir/nodes-redacted.txt" "$_bundle_dir/nodes.txt"
    fi

    # Redacted values files
    local _vf
    for _vf in "${VALUES_FILES[@]}"; do
        if [ -f "$_vf" ]; then
            local _basename
            _basename=$(basename "$_vf")
            _redact_values < "$_vf" > "$_bundle_dir/values-${_basename}"
            ok "Included redacted values: $_basename"
        fi
    done

    # Archive
    if [ -z "$_output_file" ]; then
        _output_file="biznez-support-$(date +%Y%m%d-%H%M%S).tar.gz"
    fi
    tar czf "$_output_file" -C "$_bundle_dir" .

    # Cleanup temp dir
    rm -rf "$_bundle_dir"

    ok "Support bundle created: $_output_file"
}

# ===== backup-db ============================================================
_usage_backup_db() {
    cat <<'USAGE'
Usage: biznez-cli backup-db [flags]

Create a pg_dump backup of embedded PostgreSQL.

Flags:
  -r, --release <name>    Release name (default: biznez)
  -n, --namespace <ns>    Target namespace
  --output <file>         Output file (default: biznez-backup-YYYYMMDD-HHMMSS.dump)
  -h, --help              Show this help
USAGE
}

cmd_backup_db() {
    local output=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --output) output="$2"; shift 2 ;;
            -h|--help) _usage_backup_db; return 0 ;;
            *)         die "Unknown flag for backup-db: $1" ;;
        esac
    done

    _resolve_namespace
    _require_cmd kubectl

    # Find postgres pod
    local _pg_pod
    _pg_pod=$(_find_resource pod postgres)
    if [ -z "$_pg_pod" ]; then
        die "No embedded postgres pod found for release '$RELEASE'. backup-db only works with embedded postgres." "$EXIT_KUBE"
    fi

    if [ -z "$output" ]; then
        output="biznez-backup-$(date +%Y%m%d-%H%M%S).dump"
    fi

    info "Backing up database from $_pg_pod..."
    kubectl exec "$_pg_pod" -n "$NAMESPACE" -- \
        pg_dump -U biznez -d biznez_platform --format=custom > "$output"

    local _size
    _size=$(wc -c < "$output" | awk '{printf "%.1fK", $1/1024}')
    ok "Backup created: $output ($_size)"
}

# ===== restore-db ===========================================================
_usage_restore_db() {
    cat <<'USAGE'
Usage: biznez-cli restore-db --file <backup.dump> [flags]

Restore a pg_dump backup to embedded PostgreSQL.

WARNING: This overwrites the current database.

Flags:
  --file <path>            Backup file to restore (required)
  -r, --release <name>     Release name (default: biznez)
  -n, --namespace <ns>     Target namespace
  --yes                    Skip confirmation prompt
  -h, --help               Show this help
USAGE
}

cmd_restore_db() {
    local file="" yes=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --file) file="$2"; shift 2 ;;
            --yes)  yes=true; shift ;;
            -h|--help) _usage_restore_db; return 0 ;;
            *)         die "Unknown flag for restore-db: $1" ;;
        esac
    done

    if [ -z "$file" ]; then
        die "Missing required flag: --file <backup.dump>" "$EXIT_ERROR"
    fi
    if [ ! -f "$file" ]; then
        die "Backup file not found: $file" "$EXIT_ERROR"
    fi

    _resolve_namespace
    _require_cmd kubectl

    # Find postgres pod
    local _pg_pod
    _pg_pod=$(_find_resource pod postgres)
    if [ -z "$_pg_pod" ]; then
        die "No embedded postgres pod found for release '$RELEASE'. restore-db only works with embedded postgres." "$EXIT_KUBE"
    fi

    # Confirmation
    if [ "$yes" = "false" ]; then
        printf "This will OVERWRITE the current database. Continue? [y/N] "
        local _answer
        read -r _answer
        case "$_answer" in
            y|Y|yes|Yes) ;;
            *) die "Aborted." "$EXIT_ABORT" ;;
        esac
    fi

    # Scale backend to 0
    local _backend_deploy
    _backend_deploy=$(_find_resource deployment backend)
    if [ -n "$_backend_deploy" ]; then
        info "Scaling backend to 0 replicas..."
        kubectl scale "$_backend_deploy" --replicas=0 -n "$NAMESPACE"
        sleep 5
    fi

    # Copy and restore
    info "Copying backup to postgres pod..."
    kubectl cp "$file" "$NAMESPACE/$(_echo_pod_name "$_pg_pod"):/tmp/restore.dump"

    info "Running pg_restore..."
    local _restore_rc=0
    kubectl exec "$_pg_pod" -n "$NAMESPACE" -- \
        pg_restore -U biznez -d biznez_platform --clean --if-exists /tmp/restore.dump 2>/dev/null || _restore_rc=$?

    # Clean up temp file in pod
    kubectl exec "$_pg_pod" -n "$NAMESPACE" -- rm -f /tmp/restore.dump 2>/dev/null || true

    # Scale backend back
    if [ -n "$_backend_deploy" ]; then
        info "Scaling backend back..."
        kubectl scale "$_backend_deploy" --replicas=1 -n "$NAMESPACE"
    fi

    if [ "$_restore_rc" -ne 0 ]; then
        warn "pg_restore exited with code $_restore_rc (some warnings are normal for --clean --if-exists)"
    fi

    ok "Database restore completed"

    # Health check
    info "Running post-restore health check..."
    cmd_health_check --timeout 120
}

# Helper to extract pod name from "pod/name" format
_echo_pod_name() {
    local _v="$1"
    echo "${_v#pod/}"
}

# ===== upgrade ==============================================================
_usage_upgrade() {
    cat <<'USAGE'
Usage: biznez-cli upgrade [flags] [-- <helm-flags>]

Orchestrated upgrade with pre-checks and optional rollback.

Flags:
  -f, --values <file>     Values file (can be specified multiple times)
  -r, --release <name>    Release name (default: biznez)
  -n, --namespace <ns>    Target namespace
  -h, --help              Show this help

Everything after -- is passed directly to helm upgrade.
USAGE
}

cmd_upgrade() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -f|--values) VALUES_FILES+=("$2"); shift 2 ;;
            -h|--help)   _usage_upgrade; return 0 ;;
            *)           die "Unknown flag for upgrade: $1" ;;
        esac
    done

    if [ ${#VALUES_FILES[@]} -eq 0 ]; then
        die "At least one values file is required: biznez-cli upgrade -f values.yaml" "$EXIT_VALIDATE"
    fi

    _resolve_namespace
    _require_cmd helm
    _require_cmd kubectl

    # Pre-upgrade validation
    info "Running pre-upgrade validation..."
    cmd_validate

    # Build helm command
    local _helm_args=("upgrade" "$RELEASE" "$CHART_DIR")
    local _vf
    for _vf in "${VALUES_FILES[@]}"; do
        _helm_args+=("-f" "$_vf")
    done
    _helm_args+=("--namespace" "$NAMESPACE" "--wait" "--timeout" "300s")

    if [ ${#HELM_PASSTHROUGH[@]} -gt 0 ]; then
        _helm_args+=("${HELM_PASSTHROUGH[@]}")
    fi

    info "Upgrading release '$RELEASE'..."
    local _upgrade_rc=0
    helm "${_helm_args[@]}" || _upgrade_rc=$?

    if [ "$_upgrade_rc" -ne 0 ]; then
        error "Helm upgrade failed."
        printf "Rollback to previous revision? [Y/n] "
        local _answer
        read -r _answer
        case "$_answer" in
            n|N|no|No) ;;
            *)
                info "Rolling back..."
                helm rollback "$RELEASE" -n "$NAMESPACE" || true
                ok "Rollback completed"
                ;;
        esac
        die "Upgrade failed." "$EXIT_KUBE"
    fi

    ok "Upgrade completed"

    # Post-upgrade health check
    info "Running post-upgrade health check..."
    cmd_health_check --timeout 120
}

# ---------------------------------------------------------------------------
# Section 5: Main Help, Flag Parsing, Dispatch
# ---------------------------------------------------------------------------

_usage_main() {
    cat <<USAGE
biznez-cli $CLI_VERSION -- Biznez Agentic Runtime operator CLI

Usage: biznez-cli [global-flags] <command> [command-flags] [-- <helm-flags>]

Commands (P0 -- core):
  generate-secrets    Generate cryptographic secrets for deployments
  validate            Pre-flight validation of values file and cluster
  validate-secrets    Verify K8s Secrets exist with required keys
  install             Install or upgrade via Helm
  health-check        Verify deployment health
  migrate             Run database migrations via K8s Job

Commands (P1 -- operational):
  status              Show release status and pod summary
  uninstall           Uninstall the release
  oidc-discover       Fetch OIDC provider metadata
  support-bundle      Collect diagnostic data for troubleshooting

Commands (P2 -- data management):
  backup-db           pg_dump backup of embedded PostgreSQL
  restore-db          pg_restore into embedded PostgreSQL
  upgrade             Orchestrated upgrade with pre-checks and rollback

Commands (P3 -- supply chain):
  export-images       Export container images to portable archive
  import-images       Import images from archive into registry or Docker
  verify-images       Verify image signatures and tag integrity
  build-release       Build complete release with digests, scan, SBOM, signing

Global flags:
  -n, --namespace <ns>        Target K8s namespace
  -r, --release <name>        Helm release name (default: biznez)
  -f, --values <file>         Values file (can repeat)
  --profile <eval|production> Override profile detection
  --no-color                  Disable colored output
  -v, --verbose               Enable debug output
  -h, --help                  Show this help
  --version                   Show version

Use 'biznez-cli <command> --help' for command-specific help.
USAGE
}

main() {
    # Parse global flags
    while [ $# -gt 0 ]; do
        case "$1" in
            -n|--namespace)  NAMESPACE="$2"; shift 2 ;;
            -r|--release)    RELEASE="$2"; shift 2 ;;
            -f|--values)     VALUES_FILES+=("$2"); shift 2 ;;
            --profile)       PROFILE="$2"; PROFILE_EXPLICIT=true; shift 2 ;;
            --no-color)      NO_COLOR=true; shift ;;
            -v|--verbose)    VERBOSE=true; shift ;;
            -h|--help)       _usage_main; exit 0 ;;
            --version)       echo "biznez-cli $CLI_VERSION"; exit 0 ;;
            --)              shift; HELM_PASSTHROUGH=("$@"); break ;;
            -*)              # Unknown global flag -- might be command-specific
                             break ;;
            *)               break ;;
        esac
    done

    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        generate-secrets)  cmd_generate_secrets "$@" ;;
        validate)          cmd_validate "$@" ;;
        validate-secrets)  cmd_validate_secrets "$@" ;;
        install)           cmd_install "$@" ;;
        health-check)      cmd_health_check "$@" ;;
        migrate)           cmd_migrate "$@" ;;
        status)            cmd_status "$@" ;;
        uninstall)         cmd_uninstall "$@" ;;
        oidc-discover)     cmd_oidc_discover "$@" ;;
        support-bundle)    cmd_support_bundle "$@" ;;
        backup-db)         cmd_backup_db "$@" ;;
        restore-db)        cmd_restore_db "$@" ;;
        upgrade)           cmd_upgrade "$@" ;;
        export-images)     cmd_export_images "$@" ;;
        import-images)     cmd_import_images "$@" ;;
        verify-images)     cmd_verify_images "$@" ;;
        build-release)     cmd_build_release "$@" ;;
        help)              _usage_main ;;
        *)                 die "Unknown command: $cmd. Run 'biznez-cli help' for usage." ;;
    esac
}

main "$@"
