#!/usr/bin/env bash
# =============================================================================
# biznez-cli -- Biznez Agentic Runtime operator CLI
# =============================================================================
# Single-file CLI for deploying and managing the Biznez Agentic Runtime
# platform on Kubernetes. Wraps helm, kubectl, and related tools with
# profile-aware validation, secret generation, health checking, and
# migration orchestration.
#
# Usage:
#   biznez-cli <command> [flags]
#   biznez-cli --help
#
# SECURITY: Do not run with bash -x (xtrace). Secret generation guards
# against xtrace, but operator should avoid enabling it globally.
# =============================================================================
set -euo pipefail

# ---------------------------------------------------------------------------
# Section 1: Constants & Version
# ---------------------------------------------------------------------------
readonly CLI_VERSION="0.1.0"

# Exit codes
# shellcheck disable=SC2034
readonly EXIT_OK=0
readonly EXIT_ERROR=1
readonly EXIT_PREREQ=2
readonly EXIT_VALIDATE=3
readonly EXIT_KUBE=4
readonly EXIT_SECRET=5
readonly EXIT_HEALTH=6
readonly EXIT_MIGRATE=7
readonly EXIT_NETWORK=8
# shellcheck disable=SC2034
readonly EXIT_RELEASE=9
readonly EXIT_ABORT=10
# shellcheck disable=SC2034
readonly EXIT_USAGE=11

# Default backend image for Fernet key generation
readonly DEFAULT_BACKEND_IMAGE="biznez/platform-api:latest"

# ---------------------------------------------------------------------------
# Section 2: Global State
# ---------------------------------------------------------------------------
NO_COLOR="${NO_COLOR:-false}"
VERBOSE=false
NAMESPACE=""
RELEASE="biznez"
VALUES_FILES=()
PROFILE=""
PROFILE_EXPLICIT=false
HELM_PASSTHROUGH=()
_CLEANUP_FILES=""

# Script location
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CHART_DIR="${BIZNEZ_CHART_DIR:-$REPO_ROOT/helm/biznez-runtime}"

# Source image/release functions if lib exists (development mode)
_LIB_DIR="$(cd "$(dirname "$0")/lib" 2>/dev/null && pwd)" || true
if [ -n "$_LIB_DIR" ] && [ -f "$_LIB_DIR/images.sh" ]; then
    # shellcheck source=lib/images.sh
    . "$_LIB_DIR/images.sh"
fi

# === PHASE8_LIB_INSERTION_POINT ===

# ---------------------------------------------------------------------------
# Section 3: Utility Functions
# ---------------------------------------------------------------------------

# ---- Output ---------------------------------------------------------------
_color_enabled() { [ "$NO_COLOR" = "false" ] && [ -t 1 ]; }

info() {
    if _color_enabled; then
        printf '\033[0;34m[INFO]\033[0m  %s\n' "$*"
    else
        printf '[INFO]  %s\n' "$*"
    fi
}

ok() {
    if _color_enabled; then
        printf '\033[0;32m[OK]\033[0m    %s\n' "$*"
    else
        printf '[OK]    %s\n' "$*"
    fi
}

warn() {
    if _color_enabled; then
        printf '\033[0;33m[WARN]\033[0m  %s\n' "$*" >&2
    else
        printf '[WARN]  %s\n' "$*" >&2
    fi
}

error() {
    if _color_enabled; then
        printf '\033[0;31m[ERROR]\033[0m %s\n' "$*" >&2
    else
        printf '[ERROR] %s\n' "$*" >&2
    fi
}

die() {
    error "$1"
    exit "${2:-$EXIT_ERROR}"
}

debug() {
    if [ "$VERBOSE" = "true" ]; then
        printf '[DEBUG] %s\n' "$*"
    fi
}

# ---- Prerequisites --------------------------------------------------------
_require_cmd() {
    local cmd="$1"
    local hint="${2:-}"
    if ! command -v "$cmd" >/dev/null 2>&1; then
        if [ -n "$hint" ]; then
            die "$cmd is required but not found. $hint" "$EXIT_PREREQ"
        else
            die "$cmd is required but not found." "$EXIT_PREREQ"
        fi
    fi
}

# ---- Version comparison ---------------------------------------------------
_version_gte() {
    # Returns 0 if $1 >= $2 (major.minor comparison)
    # Strips leading 'v' and non-numeric suffixes
    local raw1="$1" raw2="$2"
    local v1 v2 v1_major v1_minor v2_major v2_minor

    v1=$(echo "$raw1" | sed 's/^v//' | sed 's/[^0-9.].*$//')
    v2=$(echo "$raw2" | sed 's/^v//' | sed 's/[^0-9.].*$//')

    v1_major=$(echo "$v1" | cut -d. -f1)
    v1_minor=$(echo "$v1" | cut -d. -f2)
    v2_major=$(echo "$v2" | cut -d. -f1)
    v2_minor=$(echo "$v2" | cut -d. -f2)

    # Treat empty as 0
    v1_major="${v1_major:-0}"
    v1_minor="${v1_minor:-0}"
    v2_major="${v2_major:-0}"
    v2_minor="${v2_minor:-0}"

    # Validate numeric
    if ! echo "$v1_major" | grep -qE '^[0-9]+$' 2>/dev/null; then
        warn "Could not parse version '$raw1' — skipping version check"
        return 0
    fi
    if ! echo "$v2_major" | grep -qE '^[0-9]+$' 2>/dev/null; then
        return 0
    fi

    if [ "$v1_major" -gt "$v2_major" ]; then return 0; fi
    if [ "$v1_major" -eq "$v2_major" ] && [ "$v1_minor" -ge "$v2_minor" ]; then return 0; fi
    return 1
}

_check_version() {
    local cmd="$1" min_version="$2" actual_version="$3"
    if ! _version_gte "$actual_version" "$min_version"; then
        warn "$cmd version $actual_version is below recommended minimum $min_version"
    else
        debug "$cmd version $actual_version >= $min_version"
    fi
}

# ---- Cleanup --------------------------------------------------------------
_register_cleanup() { _CLEANUP_FILES="$_CLEANUP_FILES $1"; }

_cleanup() {
    local f
    for f in $_CLEANUP_FILES; do
        if [ -d "$f" ]; then
            rm -rf "$f" 2>/dev/null || true
        else
            rm -f "$f" 2>/dev/null || true
        fi
    done
}
trap _cleanup EXIT INT TERM

# ---- Kubernetes helpers ---------------------------------------------------
_find_resource() {
    local kind="$1" component="$2"
    kubectl get "$kind" \
        -l "app.kubernetes.io/instance=$RELEASE,app.kubernetes.io/component=$component" \
        -n "$NAMESPACE" -o name 2>/dev/null | head -1
}

_collect_optional() {
    local label="$1" outfile="$2"
    shift 2
    if "$@" > "$outfile" 2>&1; then
        ok "Collected: $label"
    else
        warn "Skipped: $label ($(head -1 "$outfile" 2>/dev/null || echo 'no output'))"
        echo "# SKIPPED: $label" > "$outfile"
    fi
}

_check_secret_key() {
    local secret="$1" key="$2"
    local _val
    _val=$(kubectl get secret "$secret" -n "$NAMESPACE" \
        -o "jsonpath={.data['$key']}" 2>/dev/null) || true
    if [ -z "$_val" ]; then
        return 1
    fi
    return 0
}

_resolve_namespace() {
    if [ -z "$NAMESPACE" ]; then
        NAMESPACE="${BIZNEZ_NAMESPACE:-}"
    fi
    if [ -z "$NAMESPACE" ]; then
        NAMESPACE=$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null) || true
        NAMESPACE="${NAMESPACE:-default}"
    fi
}

# ---- Endpoint check -------------------------------------------------------
_check_endpoint() {
    local url="$1" timeout="${2:-10}"
    local rc=0
    curl -sf --max-time "$timeout" "$url" >/dev/null 2>&1 || rc=$?
    return $rc
}

