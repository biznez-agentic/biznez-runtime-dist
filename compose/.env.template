# =============================================================================
# Biznez Agentic Runtime -- Docker Compose Environment
# =============================================================================
# Copy to .env and run setup.sh to generate secrets automatically.
# DO NOT commit .env to version control.
#
# Env var names match what the backend application expects (from config.py).
# These may differ from Helm values.yaml field names.
# =============================================================================

# =============================================================================
# Ports
# =============================================================================
# Host ports mapped to container ports. Change to avoid conflicts.
BACKEND_PORT=8000
FRONTEND_PORT=8080
GATEWAY_PORT=8090
POSTGRES_PORT=5432

# =============================================================================
# Database
# =============================================================================
POSTGRES_DB=biznez_runtime
POSTGRES_USER=biznez_user

# setup.sh replaces CHANGE_ME_DB_PASSWORD with a generated value.
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Connection string used by the backend. The password must match POSTGRES_PASSWORD.
# Host "postgres" is the compose service name (internal DNS).
DATABASE_URL=postgresql://biznez_user:CHANGE_ME_DB_PASSWORD@postgres:5432/biznez_runtime

# =============================================================================
# Security
# =============================================================================
# setup.sh generates these automatically. Do not set manually unless you know
# the required format.

# Fernet encryption key. Must be a valid Fernet key (base64, 32 bytes).
# Generated via the backend container to guarantee correct format.
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY

# JWT signing key. Any base64 string works.
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET

# =============================================================================
# Authentication
# =============================================================================
# Auth mode: local (default for evaluation, no external IdP needed)
# For OIDC, set AUTH_MODE=oidc and configure the OIDC_ variables below.
AUTH_MODE=local

# OIDC Configuration (uncomment and fill in for OIDC auth)
# OIDC_ISSUER_URL=https://your-idp.example.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_AUDIENCE=your-audience

# =============================================================================
# Application
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=info

# Uvicorn worker count. 2 is sufficient for evaluation.
WORKERS=2

# CORS allowed origins. Must include the frontend URL (nginx port, not Vite).
CORS_ORIGINS=http://localhost:8080

# =============================================================================
# LLM Provider
# =============================================================================
# Provider: openai, anthropic, none
LLM_PROVIDER=none

# OpenAI (uncomment if using)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4

# Anthropic (uncomment if using)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini (uncomment if using)
# GOOGLE_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash

# =============================================================================
# Monitoring (Langfuse)
# =============================================================================
# LLM observability. Sign up at https://cloud.langfuse.com
LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Docker Compose Settings
# =============================================================================
# Pull policy for container images. Requires docker compose v2.17+.
# Values: always, if_not_present, never
# Set to "never" for air-gapped deployments (images must be loaded locally).
# When set to "never", ensure images are present: docker image ls | grep biznez
COMPOSE_PULL_POLICY=if_not_present

# Override default images (for air-gapped or custom builds).
# BACKEND_IMAGE=ghcr.io/biznez-agentic/runtime-backend:latest
# FRONTEND_IMAGE=ghcr.io/biznez-agentic/runtime-frontend:latest
# GATEWAY_IMAGE=ghcr.io/agentgateway/agentgateway:0.1.0

# =============================================================================
# Frontend (build-time only -- READ THIS)
# =============================================================================
# VITE_* variables are baked into the frontend at BUILD TIME.
# Changing them here has NO EFFECT on an already-built frontend image.
# The compose nginx proxy routes /api/ to the backend, so the frontend
# must use relative /api paths. This variable is for reference only.
# VITE_API_BASE_URL=/api
